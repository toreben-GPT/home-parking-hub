{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "home-parking-hub",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-15",
  "secrets": {
    "required": ["ACCESS_CODE", "SESSION_SECRET"]
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "home-parking-hub-db",
      "database_id": "85fdc896-445a-48cc-885c-02a382ca3c7d"
    }
  ],
  "r2_buckets": [
    {
      "binding": "PHOTOS",
      "bucket_name": "home-parking-hub-photos"
    }
  ],
  "vars": {
    "SESSION_MAX_AGE_DAYS": "90"
  }
}
